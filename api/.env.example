NODE_ENV=development
# Default API port. Use 4001 if another service (e.g. Mako) occupies 4000.
PORT=4000

DB_HOST=localhost
# Docker Compose maps Postgres to host 5433 when local Postgres uses 5432.
DB_PORT=5433
DB_USERNAME=ngoma
DB_PASSWORD=ngoma
DB_DATABASE=ngoma
DB_SYNCHRONIZE=false

JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_refresh_in_production

REDIS_URL=redis://localhost:6379

PAWAPAY_ENVIRONMENT=sandbox
PAWAPAY_SANDBOX_API_TOKEN=
PAWAPAY_WEBHOOK_URL=http://localhost:4000/api/v1/payments/webhook

# =====================
# Payments (Mobile Money / PawaPay)
# =====================
PAYMENTS_DEV_AUTO_COMPLETE=false
PAWAPAY_ENV=sandbox
PAWAPAY_API_TOKEN=
PAWAPAY_PRODUCTION_API_TOKEN=
PAWAPAY_BASE_URL_SANDBOX=https://api.sandbox.pawapay.io/v2
PAWAPAY_BASE_URL_PROD=https://api.pawapay.io/v2
# PAWAPAY_WEBHOOK_URL=http://localhost:4001/api/v1/payments/webhook
PAWAPAY_PRIVATE_KEY=
PAWAPAY_PUBLIC_KEY_ID=

FRONTEND_URL=http://localhost:5173

# =====================
# MinIO / S3 Storage
# =====================
# Bucket is chosen by NODE_ENV unless AWS_S3_BUCKET_NAME is set explicitly.
# development → AWS_S3_BUCKET_NAME_DEV | production → AWS_S3_BUCKET_NAME_PROD
AWS_S3_ENDPOINT=https://s3.tekreminnovations.com
AWS_S3_BUCKET_NAME_DEV=ngoma-dev
AWS_S3_BUCKET_NAME_PROD=ngoma
AWS_S3_BUCKET_NAME_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_FORCE_PATH_STYLE=true
# Optional: override auto dev/prod bucket selection
# AWS_S3_BUCKET_NAME=ngoma-dev

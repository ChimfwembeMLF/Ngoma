NODE_ENV=development
# Default API port. Use 4001 if another service (e.g. Mako) occupies 4000.
PORT=4000

DB_HOST=localhost
# Docker Compose maps Postgres to host 5433 when local Postgres uses 5432.
DB_PORT=5433
DB_USERNAME=ngoma
DB_PASSWORD=ngoma
DB_DATABASE=ngoma
DB_SYNCHRONIZE=false

JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_refresh_in_production

REDIS_URL=redis://localhost:6379

PAWAPAY_ENVIRONMENT=sandbox
PAWAPAY_SANDBOX_API_TOKEN=
PAWAPAY_WEBHOOK_URL=http://localhost:4000/api/v1/payments/webhook

FRONTEND_URL=http://localhost:5173

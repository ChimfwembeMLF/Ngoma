{
  "name": "ngoma",
  "private": true,
  "packageManager": "yarn@4.17.1",
  "workspaces": [
    "api",
    "client"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "yarn workspace @ngoma/api dev",
    "dev:ui": "yarn workspace @ngoma/client dev",
    "build": "yarn workspace @ngoma/api build && yarn workspace @ngoma/client build",
    "install:all": "yarn install"
  }
}
